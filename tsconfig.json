{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2018"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "noImplicitAny": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2018"
  },
  "include": ["src/**/*.ts"]
}
